# ── WebSocket Adapter ─────────────────────────────────────────────────────
# URL REST endpoint, na który adapter wysyła gesty
WS_ADAPTER_URL=http://localhost:8000/gesture

# Minimalny poziom pewności (0.0 – 1.0), poniżej którego zdarzenia są ignorowane
WS_ADAPTER_CONFIDENCE_THRESHOLD=0.70

# Timeout (s) na pojedyncze żądanie POST
WS_ADAPTER_REQUEST_TIMEOUT=0.1
